# ============================================================
# AI Dashboard Generator — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Application -------------------------------------------
APP_ENV=development
APP_NAME="AI Dashboard Generator"
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# ----- Frontend (Next.js) ------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=dev-supabase-anon-key

# ----- Backend (FastAPI) -------------------------------------
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ----- Database (PostgreSQL) ---------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_dashboard
POSTGRES_USER=ai_dashboard_user
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql+asyncpg://ai_dashboard_user:change-this-strong-password@localhost:5432/ai_dashboard
DATABASE_URL_SYNC=postgresql://ai_dashboard_user:change-this-strong-password@localhost:5432/ai_dashboard

# ----- Redis -------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:change-this-redis-password@localhost:6379/0
CELERY_BROKER_URL=redis://:change-this-redis-password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:change-this-redis-password@localhost:6379/2

# ----- Supabase Auth & Storage --------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=dev-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=dev-supabase-service-role-key

SUPABASE_STORAGE_BUCKET=ai-dashboard-uploads

# ----- OpenAI ------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ----- Stripe ------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_PRO_MONTHLY=price_your-pro-monthly-price-id
STRIPE_PRICE_ID_PRO_ANNUAL=price_your-pro-annual-price-id
STRIPE_PRICE_ID_BUSINESS_MONTHLY=price_your-business-monthly-price-id
STRIPE_PRICE_ID_BUSINESS_ANNUAL=price_your-business-annual-price-id

# ----- Email (SMTP) ------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=your-resend-api-key
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME="InsightFlow"

# ----- File Upload Limits ------------------------------------
MAX_FILE_SIZE_FREE_MB=5
MAX_FILE_SIZE_PRO_MB=50
MAX_FILE_SIZE_BUSINESS_MB=500
MAX_FILE_SIZE_ENTERPRISE_MB=5120

# ----- Analysis Engine ---------------------------------------
ANALYSIS_TIMEOUT_SECONDS=600
MAX_ROWS_FREE=10000
MAX_ROWS_PRO=250000
MAX_ROWS_BUSINESS=1000000

# ----- AI Code Execution Sandbox -----------------------------
# Disabled by default. Configure only with an isolated remote sandbox
# provider that enforces no internet, strict timeout, CPU, and memory caps.
AI_CODE_EXECUTION_ENABLED=false
AI_CODE_EXECUTION_PROVIDER=disabled
AI_CODE_EXECUTION_ENDPOINT=
AI_CODE_EXECUTION_API_KEY=
AI_CODE_EXECUTION_TIMEOUT_SECONDS=15
AI_CODE_EXECUTION_MAX_REPAIR_ATTEMPTS=2

# ----- Hybrid Semantic Wrangling -----------------------------
# Uses LLM schema labeling and, when enabled, embeddings to merge category
# variants such as USA / U.S.A. / United States in cleaned datasets.
SEMANTIC_WRANGLING_ENABLED=true
SEMANTIC_WRANGLING_USE_EMBEDDINGS=true
SEMANTIC_WRANGLING_SIMILARITY_THRESHOLD=0.91
SEMANTIC_WRANGLING_MAX_COLUMNS=6
SEMANTIC_WRANGLING_MAX_UNIQUE_VALUES=80

# ----- Rate Limiting -----------------------------------------
RATE_LIMIT_PER_MINUTE_AUTHENTICATED=100
RATE_LIMIT_PER_MINUTE_UNAUTHENTICATED=20

# ----- Logging -----------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----- Sentry (Error Tracking) --------------------------------
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# ----- Docker ------------------------------------------------
DOCKER_REGISTRY=your-registry.io
DOCKER_IMAGE_TAG=latest
